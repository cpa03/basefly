{
  "name": "@saasfly/api",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./env": "./src/env.mjs",
    "./edge": "./src/edge.ts",
    "./transformer": "./src/transformer.ts",
    "./subscriptions": "./src/subscriptions.ts",
    "./request-id": "./src/request-id.ts",
    "./server": "./src/root.ts",
    "./openapi": "./src/openapi.ts"
  },
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "lint": "eslint . --cache --cache-location 'node_modules/.cache/.eslintcache'",
    "format": "prettier --check '**/*.{mjs,ts,json}' ",
    "typecheck": "tsc --noEmit",
    "generate-docs": "npx tsx src/docs-generator.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.4",
    "@saasfly/common": "workspace:*",
    "@saasfly/db": "workspace:*",
    "@saasfly/stripe": "workspace:*",
    "@trpc/server": "11.10.0",
    "@t3-oss/env-nextjs": "0.13.10",
    "ioredis": "^5.6.0",
    "next": "16.2.7",
    "superjson": "2.2.6",
    "dinero.js": "2.0.0-alpha.16",
    "zod": "4.3.6",
    "trpc-openapi": "^1.2.0"
  },
  "devDependencies": {
    "@saasfly/eslint-config": "workspace:*",
    "@saasfly/prettier-config": "workspace:*",
    "@saasfly/typescript-config": "workspace:*",
    "eslint": "8.57.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@saasfly/eslint-config/base"
    ]
  },
  "prettier": "@saasfly/prettier-config"
}
